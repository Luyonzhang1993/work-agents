# Test your FastAPI endpoints

GET http://127.0.0.1:8001/
Accept: application/json

###

GET http://127.0.0.1:8001/health
Accept: application/json

###

POST http://127.0.0.1:8001/api/chat
Content-Type: application/json
Accept: application/json

{
  "message": "请帮我计算 12.5 加 7.5",
  "use_tools": true
}

###

GET http://127.0.0.1:8001/api/mcp/tools
Accept: application/json

###

POST http://127.0.0.1:8001/api/mcp/call
Content-Type: application/json
Accept: application/json

{
  "name": "mcp:arithmetic:multiply",
  "arguments": {
    "left": 6,
    "right": 7
  }
}

###

POST http://127.0.0.1:8001/api/mcp/call
Content-Type: application/json
Accept: application/json

{
  "name": "mcp:alphavantage:TOOL_CALL",
  "arguments": {
    "tool_name": "TIME_SERIES_DAILY",
    "arguments": {
      "symbol": "AMD"
    }
  }
}

###

GET http://127.0.0.1:8001/api/workflows/finance-report
Accept: application/json

###

POST http://127.0.0.1:8001/api/workflows/finance-report/run
Content-Type: application/json
Accept: application/json

{
  "symbol": "AMD"
}

###

GET http://127.0.0.1:8001/api/workflows/travel-planner
Accept: application/json

###

POST http://127.0.0.1:8001/api/workflows/travel-planner/run
Content-Type: application/json
Accept: application/json

{
  "destination": "杭州",
  "duration_days": 3,
  "budget_level": "comfort",
  "traveler_type": "couple",
  "interests": ["local_food", "culture", "city_walk"]
}

###

POST http://127.0.0.1:8001/api/workflows/travel-planner/stream
Content-Type: application/json
Accept: text/event-stream

{
  "destination": "京都",
  "duration_days": 4,
  "budget_level": "premium",
  "traveler_type": "family",
  "interests": ["culture", "local_food", "nature"]
}

###

POST http://127.0.0.1:8001/api/chat
Content-Type: application/json
Accept: application/json

{
  "message": "请运行 AMD 金融报告 workflow，并告诉我结果",
  "use_tools": true
}

###

POST http://127.0.0.1:8001/api/chat
Content-Type: application/json
Accept: application/json

{
  "message": "帮我规划一个杭州 3 天情侣旅行，预算舒适，想吃本地美食和逛文化街区",
