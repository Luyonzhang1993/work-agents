GET http://127.0.0.1:8001/api/mcp/tools
Accept: application/json

###

POST http://127.0.0.1:8001/api/mcp/call
Content-Type: application/json
Accept: application/json

{
  "name": "mcp:arithmetic:multiply",
  "arguments": {
    "left": 6,
    "right": 7
  }
}

###

POST http://127.0.0.1:8001/api/mcp/call
Content-Type: application/json
Accept: application/json

{
  "name": "mcp:alphavantage:TOOL_CALL",
  "arguments": {
    "tool_name": "TIME_SERIES_DAILY",
    "arguments": {
      "symbol": "AMD"
    }
  }
}

